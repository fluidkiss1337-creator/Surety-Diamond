# Surety Diamond — Environment Variables
# Copy this file to .env and fill in your values before deploying.
#
#   cp .env.example .env

# Deployer private key (uint256, no 0x prefix)
PRIVATE_KEY=

# Initial diamond owner address
OWNER_ADDRESS=

# Treasury address for emergency withdrawals (defaults to OWNER_ADDRESS if omitted)
TREASURY_ADDRESS=

# Ethereum RPC endpoint
RPC_URL=

# Etherscan API key for contract verification (optional)
ETHERSCAN_API_KEY=
